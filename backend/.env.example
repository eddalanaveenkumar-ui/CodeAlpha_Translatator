# Server Configuration
PORT=5000

# Google Cloud Translation API Key (Optional fallback if Microsoft not set)
# Get a key from Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_API_KEY=

# Microsoft Translator API Key & Region (Optional fallback if Google not set)
# Get a key from Azure Portal -> Cognitive Services -> Translator
MICROSOFT_API_KEY=
MICROSOFT_LOCATION=global

# MyMemory Translation API Settings (Optional Key or Email)
# Add your key or email to increase limits from 1,000 words/day to 30,000 words/day
MYMEMORY_KEY=
MYMEMORY_EMAIL=

